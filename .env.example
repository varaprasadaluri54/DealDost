# DealDost Configuration - Required Keys

# --- FRONTEND (React/Vite) ---
# The URL of your backend proxy.
# For local development, this is typically http://localhost:5000/api
VITE_API_URL=http://localhost:5000/api

# --- BACKEND PROXY ---
# The port your proxy server will run on
PORT=5000

# --- E-COMMERCE API KEYS ---
# Choose ONE of the following depending on your data provider:

# 1. DataYuge (Recommended for India: Amazon.in, Flipkart)
# Get yours at: https://datayuge.com/
DATAYUGE_API_KEY=your_datayuge_key_here

# 2. RapidAPI (Alternative)
# Get yours at: https://rapidapi.com/
RAPIDAPI_KEY=your_rapidapi_key_here

# 3. Google Gemini (AI Search)
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_key_here

# --- AFFILIATE IDS ---
# Your personal tracking IDs for monetization
AMAZON_AFFILIATE_ID=mytag-21
FLIPKART_AFFILIATE_ID=affid-123
MYNTRA_AFFILIATE_ID=myntra-aff
